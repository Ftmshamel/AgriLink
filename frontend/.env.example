# --- AgriLink frontend env ---
# Copy this file to `.env` and fill in real values to enable cloud features.

# Python AI backend (default points to local dev server)
VITE_API_URL=http://localhost:8000

# --- Firebase (optional) ---
# When all of the values below are set, AgriLink uses real Firebase Auth + Firestore.
# Otherwise it falls back to localStorage-backed demo mode.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MSG_SENDER_ID=
VITE_FIREBASE_APP_ID=
